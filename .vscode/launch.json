{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-cli",
            "program": "${workspaceFolder}/WeeklyReport/CLI/bin/Debug/net10.0/owreport.dll",
            "args": [],
            "cwd": "${workspaceFolder}/WeeklyReport/CLI",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "PATH": "/Users/gianluigi.calcaterra/.dotnet-local:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
                "DOTNET_ROOT": "/Users/gianluigi.calcaterra/.dotnet-local"
            }
        },
        {
            "name": "UI (Mac Catalyst)",
            "type": "node",
            "request": "launch",
            "noDebug": true,
            "runtimeExecutable": "/Users/gianluigi.calcaterra/.dotnet-local/dotnet",
            "runtimeArgs": ["run", "--project"],
            "program": "${workspaceFolder}/WeeklyReport/UI/UI.csproj",
            "args": ["-f", "net8.0-maccatalyst"],
            "cwd": "${workspaceFolder}/WeeklyReport/UI",
            "console": "integratedTerminal",
            "env": {
                "DOTNET_ROOT": "/Users/gianluigi.calcaterra/.dotnet-local"
            }
