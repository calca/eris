{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CLI (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-cli",
            "program": "${workspaceFolder}/WeeklyReport/CLI/bin/Debug/net8.0/owreport.dll",
            "args": [],
            "cwd": "${workspaceFolder}/WeeklyReport/CLI",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "PATH": "/usr/local/share/dotnet:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
            }
        },
        {
            "name": "UI (Mac Catalyst)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-ui",
            "program": "${workspaceFolder}/WeeklyReport/UI/bin/Debug/net8.0-maccatalyst/UI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/WeeklyReport/UI",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "PATH": "/Users/gianluigi.calcaterra/.dotnet-local:/usr/local/share/dotnet:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin",
                "DOTNET_ROOT": "/Users/gianluigi.calcaterra/.dotnet-local"
            }
        }
    ]
}
