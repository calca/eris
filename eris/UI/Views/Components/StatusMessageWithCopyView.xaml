<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:eris.UI.Resources.Strings"
             x:Class="eris.UI.Views.Components.StatusMessageWithCopyView"
             x:Name="Root">

    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <Label Grid.Column="0"
               Text="{Binding Source={x:Reference Root}, Path=Message}"
               FontSize="{Binding Source={x:Reference Root}, Path=MessageFontSize}"
               FontAttributes="{Binding Source={x:Reference Root}, Path=MessageFontAttributes}"
               TextColor="{StaticResource Error}"
               HorizontalTextAlignment="{Binding Source={x:Reference Root}, Path=MessageHorizontalTextAlignment}"
               LineBreakMode="WordWrap"
               VerticalOptions="Center" />
        <Button Grid.Column="1"
            Text="{x:Static strings:AppStrings.Copy}"
                Style="{StaticResource SecondaryBtn}"
                FontSize="12"
                HeightRequest="36"
                Padding="10,0"
                Command="{Binding Source={x:Reference Root}, Path=CopyCommand}" />
    </Grid>
</ContentView>
