<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eris.UI.ViewModels"
             xmlns:strings="clr-namespace:eris.UI.Resources.Strings"
             x:Class="eris.UI.Views.Components.Dialogs.FiltersDialogView"
             x:DataType="vm:MainViewModel">

    <Grid IsVisible="{Binding IsFiltersDialogOpen}"
          BackgroundColor="{AppThemeBinding Light=#88000000, Dark=#CC000000}">
        <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
               BorderColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
               CornerRadius="16"
               HasShadow="False"
               Padding="24"
               WidthRequest="360"
               HorizontalOptions="Center"
               VerticalOptions="Center">
            <VerticalStackLayout Spacing="12">
                <Label Text="{x:Static strings:AppStrings.Filters}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                       HorizontalOptions="Center" />

                <Label Text="{x:Static strings:AppStrings.FiltersDialogDescription}"
                       Style="{StaticResource MutedLabel}"
                       HorizontalTextAlignment="Center" />

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <Label Grid.Column="0"
                           Text="{x:Static strings:AppStrings.ExcludeTentativeLabel}"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                           FontSize="13"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Switch Grid.Column="1"
                            IsToggled="{Binding DialogExcludeTentative}"
                            OnColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                </Grid>

                <Label Text="{x:Static strings:AppStrings.CategoriesTagLabel}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       FontSize="13"
                       FontAttributes="Bold" />
                <Entry Text="{Binding DialogExcludedCategories}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                       PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                       Placeholder="Personale, OOO"
                       Keyboard="Default"
                       FontSize="13" />

                <Label Text="{x:Static strings:AppStrings.ClientLabel}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       FontSize="13"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />
                <Entry Text="{Binding DialogExcludedClients}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                       PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                       Placeholder="ClienteX, ClienteY"
                       Keyboard="Default"
                       FontSize="13" />

                <Label Text="{x:Static strings:AppStrings.ProjectLabel}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       FontSize="13"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />
                <Entry Text="{Binding DialogExcludedProjects}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                       PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                       Placeholder="ProgettoA, ProgettoB"
                       Keyboard="Default"
                       FontSize="13" />

                <Label Text="{x:Static strings:AppStrings.TopicLabel}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       FontSize="13"
                       FontAttributes="Bold"
                       Margin="0,4,0,0" />
                <Entry Text="{Binding DialogExcludedTopics}"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                       BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                       PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                       Placeholder="TopicX, TopicY"
                       Keyboard="Default"
                       FontSize="13" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,10,0,0">
                    <Button Grid.Column="0"
                            Text="{x:Static strings:AppStrings.Cancel}"
                            Style="{StaticResource SecondaryBtn}"
                            HeightRequest="44"
                            Command="{Binding CancelFiltersDialogCommand}" />
                    <Button Grid.Column="1"
                            Text="{x:Static strings:AppStrings.Save}"
                            Style="{StaticResource PrimaryBtn}"
                            HeightRequest="44"
                            Command="{Binding ApplyFiltersDialogCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentView>
