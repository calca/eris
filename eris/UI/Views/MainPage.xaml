<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eris.UI.ViewModels"
             xmlns:conv="clr-namespace:eris.UI.Converters"
             xmlns:views="clr-namespace:eris.UI.Views"
             xmlns:strings="clr-namespace:eris.UI.Resources.Strings"
             x:Class="eris.UI.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ThemeLabel}"
                     Command="{Binding ToggleThemeCommand}" />
        <ToolbarItem Text="{Binding ToggleConfigLabel}"
                     Command="{Binding ToggleConfigCommand}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:BoolToColorConverter x:Key="AuthStatusColor"
                                   TrueColor="#16a34a"
                                   FalseColor="#64748b" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 1: HOME  ═════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsGenerateTab}">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- Banner configurazione mancante -->
                <Label IsVisible="{Binding IsConfigIncomplete}"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,16">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{x:Static strings:AppStrings.ConfigureBannerText}" />
                            <Span Text="&#x2197;" FontSize="18" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Logo -->
                <Image Source="eris_logo.png"
                       HeightRequest="240"
                       HorizontalOptions="Center"
                       Margin="0,12,0,16" />

                <!-- Messaggio benvenuto (visibile solo se config incompleta) -->
                <VerticalStackLayout IsVisible="{Binding IsConfigIncomplete}" Spacing="8" Margin="0,0,0,24">
                    <Label Text="{x:Static strings:AppStrings.Welcome}"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           Margin="0,12,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.2*" />
                            <ColumnDefinition Width="0.6*" />
                            <ColumnDefinition Width="0.2*" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="1"
                               Text="{x:Static strings:AppStrings.WelcomeDescription}"
                               FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Contenuto principale (nascosto se config incompleta) -->
                <VerticalStackLayout Spacing="0"
                                     IsVisible="{Binding IsConfigIncomplete, Converter={StaticResource InvertBool}}">

                <!-- Intestazione -->
                <Label Text="{x:Static strings:AppStrings.ExportMeetingsTitle}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}"
                       Margin="0,12,0,24" />

                <Label Text="{x:Static strings:AppStrings.HereIsYourReport}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       IsVisible="{Binding ShowResult}"
                       Margin="0,12,0,24" />

                <!-- ── Periodo (slider) ────────────────────────────────── -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="0"
                        HeightRequest="46"
                        HorizontalOptions="FillAndExpand"
                        Margin="40,0,40,16"
                        IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="23" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*,*">
                        <Button Grid.Column="0"
                                Text="{x:Static strings:AppStrings.ThisWeek}"
                                Command="{Binding SelectThisWeekCommand}"
                                Margin="4" CornerRadius="19"
                                FontSize="13" Padding="0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsThisWeekSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="FontAttributes" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsThisWeekSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                    <Setter Property="FontAttributes" Value="None" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="1"
                                Text="{x:Static strings:AppStrings.PreviousWeek}"
                                Command="{Binding SelectCurrentMonthCommand}"
                                Margin="4" CornerRadius="19"
                                FontSize="13" Padding="0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsCurrentMonthSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="FontAttributes" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsCurrentMonthSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                    <Setter Property="FontAttributes" Value="None" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Grid.Column="2"
                                Text="{x:Static strings:AppStrings.CustomPeriod}"
                                Command="{Binding SelectCustomPeriodCommand}"
                                Margin="4" CornerRadius="19"
                                FontSize="13" Padding="0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsCustomPeriodSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                    <Setter Property="TextColor" Value="White" />
                                    <Setter Property="FontAttributes" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsCustomPeriodSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                    <Setter Property="FontAttributes" Value="None" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </Border>

                <!-- Periodo selezionato -->
                <Border BackgroundColor="Transparent"
                        Stroke="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                        StrokeThickness="1.5"
                        HorizontalOptions="FillAndExpand"
                        Margin="40,4,40,20"
                        Padding="16,12"
                        IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <!-- Riga Lun-Ven -->
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <ImageButton WidthRequest="24" HeightRequest="24"
                                         BackgroundColor="Transparent"
                                         Padding="0"
                                         VerticalOptions="Center"
                                         Command="{Binding ToggleWorkWeekCommand}">
                                <ImageButton.Triggers>
                                    <DataTrigger TargetType="ImageButton" Binding="{Binding IsWorkWeek}" Value="True">
                                        <Setter Property="Source" Value="week_fading.png" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="ImageButton" Binding="{Binding IsWorkWeek}" Value="False">
                                        <Setter Property="Source" Value="week.png" />
                                    </DataTrigger>
                                </ImageButton.Triggers>
                            </ImageButton>
                            <Label Text="{Binding WorkWeekLabel}"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleWorkWeekCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                        <!-- Riga Date -->
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <ImageButton WidthRequest="24" HeightRequest="24"
                                         BackgroundColor="Transparent"
                                         Padding="0"
                                         VerticalOptions="Center"
                                         Command="{Binding OpenDatePickerCommand}"
                                         IsEnabled="{Binding IsCustomPeriodSelected}">
                                <ImageButton.Triggers>
                                    <DataTrigger TargetType="ImageButton" Binding="{Binding IsCustomPeriodSelected}" Value="True">
                                        <Setter Property="Source" Value="calendar_clock.png" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="ImageButton" Binding="{Binding IsCustomPeriodSelected}" Value="False">
                                        <Setter Property="Source" Value="calendar.png" />
                                    </DataTrigger>
                                </ImageButton.Triggers>
                            </ImageButton>
                            <Label Text="{Binding WeekRangeDisplay}"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenDatePickerCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ── Pulsante Genera ────────────────────────────────────── -->
                <Grid HeightRequest="52"
                      IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}"
                      Margin="40,0,40,12">
                    <Button Style="{StaticResource PrimaryBtn}"
                            FontSize="15"
                            HeightRequest="52"
                            Command="{Binding GenerateReportCommand}"
                            HorizontalOptions="FillAndExpand">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                <Setter Property="Text" Value="{x:Static strings:AppStrings.GenerateReport}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Text" Value="" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HeightRequest="26"
                                       WidthRequest="26" />
                </Grid>

                  <!-- ── Errore ─────────────────────────────────────────────── -->
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="8"
                        IsVisible="{Binding HasError}"
                        Margin="0,0,0,12">
                      <Label Grid.Column="0"
                          Text="{Binding ErrorMessage}"
                          FontSize="17"
                          FontAttributes="Bold"
                          TextColor="{StaticResource Error}"
                          HorizontalTextAlignment="Center"
                          LineBreakMode="WordWrap"
                          VerticalOptions="Center" />
                      <Button Grid.Column="1"
                          Text="{x:Static strings:AppStrings.Copy}"
                          Style="{StaticResource SecondaryBtn}"
                          FontSize="12"
                          HeightRequest="36"
                          Padding="10,0"
                          Command="{Binding CopyStatusCommand}" />
                  </Grid>

                <!-- ── Risultato: cerchi statistiche ──────────────────────────── -->
                <HorizontalStackLayout IsVisible="{Binding ShowResult}"
                                       HorizontalOptions="Center"
                                       Spacing="20"
                                       Margin="0,0,0,8">

                    <!-- Periodo -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center"
                                         WidthRequest="150">
                        <Label Text="{x:Static strings:AppStrings.PeriodLabel}"
                               FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ResultPeriodStart}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                               HorizontalOptions="Center" />
                        <Label Text="–"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ResultPeriodEnd}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <views:CircularStatView IconSource="report_hours.png"
                                            StatLabel="{x:Static strings:AppStrings.HoursLabel}"
                                            Value="{Binding TotalHours, StringFormat='{0:F1}h'}"
                                            Progress="{Binding HoursProgress}" />

                    <views:CircularStatView IconSource="report_meetings.png"
                                            StatLabel="{x:Static strings:AppStrings.MeetingsLabel}"
                                            Value="{Binding MeetingCount, StringFormat='{0}'}"
                                            Progress="{Binding MeetingProgress}" />

                </HorizontalStackLayout>

                <!-- Bottoni post-risultato -->
                <VerticalStackLayout IsVisible="{Binding ShowResult}" Spacing="8" Margin="0,12,0,12">
                    <Button Text="{x:Static strings:AppStrings.NewReport}"
                            Style="{StaticResource SecondaryBtn}"
                            HeightRequest="52"
                            FontSize="15"
                            HorizontalOptions="FillAndExpand"
                            Command="{Binding NuovoReportCommand}" />
                    <Button Text="{x:Static strings:AppStrings.OpenReport}"
                            Style="{StaticResource PrimaryBtn}"
                            HeightRequest="52"
                            FontSize="15"
                            HorizontalOptions="FillAndExpand"
                            Command="{Binding OpenResultCommand}" />
                </VerticalStackLayout>

                </VerticalStackLayout>
                <!-- fine: Contenuto principale -->

            </VerticalStackLayout>
        </ScrollView>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 2: CONFIGURAZIONE  ════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsConfigTab}">
            <VerticalStackLayout Padding="20,32,20,32" Spacing="0">

                <!-- ── Sorgente Calendario ─────────────────────────── -->
                <Grid ColumnDefinitions="45*,20*,35*" ColumnSpacing="0" Margin="0,0,0,32" Padding="0">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="{x:Static strings:AppStrings.ChooseSource}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap" />

                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                StrokeThickness="0"
                                HeightRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="23" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,*">
                                <Button Grid.Column="0"
                                        Text="ICS Calendar"
                                        Command="{Binding SelectSourceIcsCommand}"
                                        Margin="4" CornerRadius="19"
                                        FontSize="14" Padding="0">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="False">
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                            <Setter Property="FontAttributes" Value="None" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Button Grid.Column="1"
                                        Text="Outlook"
                                        Command="{Binding SelectSourceGraphCommand}"
                                        Margin="4" CornerRadius="19"
                                        FontSize="14" Padding="0">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="FontAttributes" Value="Bold" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="False">
                                            <Setter Property="BackgroundColor" Value="Transparent" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                            <Setter Property="FontAttributes" Value="None" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Formato Subject -->
                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                        <Label Text="{x:Static strings:AppStrings.TitleStructure}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap" />
                        <Button Text="{x:Static strings:AppStrings.SubjectFormat}"
                                Style="{StaticResource SecondaryBtn}"
                                HeightRequest="46"
                                FontSize="13"
                                Padding="16,8"
                                Command="{Binding OpenTemplateDialogCommand}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- ── URL ICS ─────────────────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,32" Padding="0,4"
                                    IsVisible="{Binding IsIcsSource}">
                        <Label Text="{x:Static strings:AppStrings.IcsUrlDescription}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap"
                               Margin="0,0,0,4" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalOptions="Center">
                            <Entry Grid.Column="0"
                                   Text="{Binding IcsUrl}"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                                   Placeholder="https://example.com/calendar.ics"
                                   Keyboard="Default"
                                   FontSize="13" />
                            <Button Grid.Column="1"
                                    Text="ⓘ"
                                    FontSize="20"
                                    WidthRequest="36" HeightRequest="36"
                                    CornerRadius="18"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                                    Padding="0"
                                    VerticalOptions="Center"
                                    Command="{Binding ShowIcsHelpCommand}" />
                        </Grid>
                </VerticalStackLayout>

                <!-- ── Account Microsoft ───────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,32" Padding="0,4"
                                    IsVisible="{Binding IsGraphSource}">
                        <Label Text="{x:Static strings:AppStrings.MicrosoftAccountDescription}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap"
                               Margin="0,0,0,4" />

                        <Grid ColumnDefinitions="45*,20*,35*" ColumnSpacing="0">
                            <Grid Grid.Column="0" ColumnDefinitions="*,Auto" ColumnSpacing="8"
                                  IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                                <Button Grid.Column="0"
                                        Text="{x:Static strings:AppStrings.LoginWithMicrosoft}"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding LoginCommand}"
                                        IsVisible="{Binding IsNotAuthenticated}" />
                                <Button Grid.Column="0"
                                        Text="{x:Static strings:AppStrings.AuthenticatedLabel}"
                                        Style="{StaticResource PrimaryBtn}"
                                        BackgroundColor="{StaticResource Success}"
                                        IsEnabled="False"
                                        IsVisible="{Binding IsAuthenticated}" />
                                <Button Grid.Column="1"
                                        Text="{x:Static strings:AppStrings.SignOut}"
                                        Style="{StaticResource DangerBtn}"
                                        Command="{Binding LogoutCommand}"
                                        IsVisible="{Binding IsAuthenticated}" />
                            </Grid>

                            <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                <Ellipse WidthRequest="10" HeightRequest="10" VerticalOptions="Center"
                                         Fill="{Binding IsAuthenticated, Converter={StaticResource AuthStatusColor}}" />
                                <Label Text="{Binding UserDisplayName}"
                                       Style="{StaticResource SubtitleLabel}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Frame IsVisible="{Binding HasDeviceCode}"
                               BackgroundColor="{AppThemeBinding Light={StaticResource DeviceCodeBgLight}, Dark={StaticResource DeviceCodeBgDark}}" BorderColor="#0284c7"
                               CornerRadius="8" Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{x:Static strings:AppStrings.DeviceCodeAuthLabel}"
                                       Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding DeviceCodeMessage}"
                                       TextColor="{StaticResource PrimaryLight}"
                                       FontSize="12" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="32" />

                           <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8"
                              IsVisible="{Binding HasAuthError}"
                              Margin="0,2,0,0">
                            <Label Grid.Column="0"
                                Text="{Binding AuthErrorMessage}"
                                FontSize="14"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Error}"
                                HorizontalTextAlignment="Start"
                                LineBreakMode="WordWrap"
                                VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                 Text="{x:Static strings:AppStrings.Copy}"
                                 Style="{StaticResource SecondaryBtn}"
                                 FontSize="12"
                                 HeightRequest="36"
                                 Padding="10,0"
                                 Command="{Binding CopyStatusCommand}" />
                           </Grid>
                </VerticalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                         Margin="0,4,0,4" />

                <!-- ── Cartella di output ──────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,32" Padding="0,4">
                        <Label Text="{x:Static strings:AppStrings.OutputFolderDescription}"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap"
                               Margin="0,0,0,4" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                    StrokeThickness="0"
                                    Padding="12,0"
                                    HeightRequest="46">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding OutputFolderName}"
                                       ToolTipProperties.Text="{Binding OutputFolder}"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" />
                            </Border>
                            <Button Grid.Column="1"
                                    Text="{x:Static strings:AppStrings.SelectButton}"
                                    Style="{StaticResource SecondaryBtn}"
                                    FontSize="13"
                                    Command="{Binding SelectFolderCommand}" />
                            <Button Grid.Column="2"
                                    Text="↗"
                                    Style="{StaticResource SecondaryBtn}"
                                    WidthRequest="44"
                                    Command="{Binding OpenOutputFolderCommand}" />
                        </Grid>
                </VerticalStackLayout>

                <!-- ── Formato esportazione + Ore settimanali ────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,32" Padding="0,4">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <!-- Formato -->
                            <VerticalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="{x:Static strings:AppStrings.ExportFormatDescription}"
                                       Style="{StaticResource MutedLabel}"
                                       LineBreakMode="WordWrap"
                                        HeightRequest="36"
                                       Margin="0,0,0,4" />
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                        StrokeThickness="0"
                                        HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="23" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,*">
                                        <Button Grid.Column="0"
                                                Text="XLSX"
                                                Command="{Binding SelectFormatXlsxCommand}"
                                                Margin="4" CornerRadius="19"
                                                FontSize="14" Padding="0">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                                    <Setter Property="TextColor" Value="White" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                                    <Setter Property="FontAttributes" Value="None" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Text="CSV"
                                                Command="{Binding SelectFormatCsvCommand}"
                                                Margin="4" CornerRadius="19"
                                                FontSize="14" Padding="0">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                                    <Setter Property="TextColor" Value="White" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                                                    <Setter Property="FontAttributes" Value="None" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                            <!-- Ore settimanali -->
                            <VerticalStackLayout Grid.Column="1" Spacing="8">
                                <Label Text="{x:Static strings:AppStrings.WeeklyHoursDescription}"
                                       Style="{StaticResource MutedLabel}"
                                       LineBreakMode="WordWrap"
                                        HeightRequest="36"
                                       Margin="0,0,0,4" />
                                <Entry Text="{Binding WeeklyWorkingHours}"
                                       TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                                       Placeholder="40"
                                       Keyboard="Numeric"
                                       HeightRequest="46"
                                       FontSize="15"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- Filtri -->
                            <VerticalStackLayout Grid.Column="2" Spacing="8">
                                <Label Text="{x:Static strings:AppStrings.FiltersActivityDescription}"
                                       Style="{StaticResource MutedLabel}"
                                       LineBreakMode="WordWrap"
                                        HeightRequest="36"
                                       Margin="0,0,0,4" />
                                <Grid>
                                    <Button Text="{x:Static strings:AppStrings.Filters}"
                                            Style="{StaticResource SecondaryBtn}"
                                          HeightRequest="46"
                                            FontSize="13"
                                            Padding="16,8"
                                            Command="{Binding OpenFiltersDialogCommand}" />

                                    <Border IsVisible="{Binding HasActiveFilters}"
                                            BackgroundColor="{StaticResource Primary}"
                                            StrokeThickness="0"
                                            WidthRequest="10"
                                            HeightRequest="10"
                                            HorizontalOptions="End"
                                            VerticalOptions="Start"
                                            Margin="0,4,6,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="5" />
                                        </Border.StrokeShape>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                </VerticalStackLayout>

                <!-- ── Chiudi ──────────────────────────────────────────── -->
                <Button Text="{x:Static strings:AppStrings.CloseGoHome}"
                        Style="{StaticResource SecondaryBtn}"
                        HeightRequest="52"
                        FontSize="15"
                        HorizontalOptions="FillAndExpand"
                        Margin="0,8,0,0"
                        Command="{Binding SelectTabGenerateCommand}" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Dialog selezione periodo ──────────────────────────────────── -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsDatePickerOpen}"
              BackgroundColor="{AppThemeBinding Light=#88000000, Dark=#CC000000}">
            <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                   BorderColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                   CornerRadius="16" HasShadow="False"
                   Padding="28" WidthRequest="320"
                   HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="16">

                    <Label Text="{x:Static strings:AppStrings.SelectPeriodTitle}"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{x:Static strings:AppStrings.FromLabel}" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                        <DatePicker Date="{Binding DialogStartDate}"
                                    Format="dd/MM/yyyy"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                    HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{x:Static strings:AppStrings.ToLabel}" FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}" />
                        <DatePicker Date="{Binding DialogEndDate}"
                                    Format="dd/MM/yyyy"
                                    TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                                    HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Grid.Column="0" Text="{x:Static strings:AppStrings.Cancel}"
                                Style="{StaticResource SecondaryBtn}"
                                HeightRequest="44"
                                Command="{Binding CancelDatePickerCommand}" />
                        <Button Grid.Column="1" Text="{x:Static strings:AppStrings.Confirm}"
                                Style="{StaticResource PrimaryBtn}"
                                HeightRequest="44"
                                Command="{Binding ConfirmDatePickerCommand}" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>
        </Grid>

             <!-- ── Dialog filtri attività ─────────────────────────────────────── -->
             <Grid Grid.RowSpan="2" IsVisible="{Binding IsFiltersDialogOpen}"
                BackgroundColor="{AppThemeBinding Light=#88000000, Dark=#CC000000}">
                 <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                     BorderColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                     CornerRadius="16" HasShadow="False"
                     Padding="24" WidthRequest="360"
                     HorizontalOptions="Center" VerticalOptions="Center">
                  <VerticalStackLayout Spacing="12">

                      <Label Text="{x:Static strings:AppStrings.Filters}"
                          FontSize="18"
                          FontAttributes="Bold"
                          TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                          HorizontalOptions="Center" />

                      <Label Text="{x:Static strings:AppStrings.FiltersDialogDescription}"
                          Style="{StaticResource MutedLabel}"
                          HorizontalTextAlignment="Center" />

                      <!-- Escludi tentative -->
                      <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                          <Label Grid.Column="0"
                              Text="{x:Static strings:AppStrings.ExcludeTentativeLabel}"
                              TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                              FontSize="13"
                              FontAttributes="Bold"
                              VerticalOptions="Center" />
                          <Switch Grid.Column="1"
                              IsToggled="{Binding DialogExcludeTentative}"
                              OnColor="{StaticResource Primary}"
                              VerticalOptions="Center" />
                      </Grid>

                      <Label Text="{x:Static strings:AppStrings.CategoriesTagLabel}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          FontSize="13"
                          FontAttributes="Bold" />
                      <Entry Text="{Binding DialogExcludedCategories}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                          PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                          Placeholder="Personale, OOO"
                          Keyboard="Default"
                          FontSize="13" />

                      <Label Text="{x:Static strings:AppStrings.ClientLabel}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          FontSize="13"
                          FontAttributes="Bold"
                          Margin="0,4,0,0" />
                      <Entry Text="{Binding DialogExcludedClients}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                          PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                          Placeholder="ClienteX, ClienteY"
                          Keyboard="Default"
                          FontSize="13" />

                      <Label Text="{x:Static strings:AppStrings.ProjectLabel}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          FontSize="13"
                          FontAttributes="Bold"
                          Margin="0,4,0,0" />
                      <Entry Text="{Binding DialogExcludedProjects}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                          PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                          Placeholder="ProgettoA, ProgettoB"
                          Keyboard="Default"
                          FontSize="13" />

                      <Label Text="{x:Static strings:AppStrings.TopicLabel}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          FontSize="13"
                          FontAttributes="Bold"
                          Margin="0,4,0,0" />
                      <Entry Text="{Binding DialogExcludedTopics}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                          PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                          Placeholder="TopicX, TopicY"
                          Keyboard="Default"
                          FontSize="13" />

                      <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                       <Button Grid.Column="0"
                            Text="{x:Static strings:AppStrings.Cancel}"
                            Style="{StaticResource SecondaryBtn}"
                            HeightRequest="44"
                            Command="{Binding CancelFiltersDialogCommand}" />
                       <Button Grid.Column="1"
                            Text="{x:Static strings:AppStrings.Save}"
                            Style="{StaticResource PrimaryBtn}"
                            HeightRequest="44"
                            Command="{Binding ApplyFiltersDialogCommand}" />
                      </Grid>

                  </VerticalStackLayout>
                 </Frame>
             </Grid>

             <!-- ── Dialog formato subject ─────────────────────────────────────── -->
             <Grid Grid.RowSpan="2" IsVisible="{Binding IsTemplateDialogOpen}"
                BackgroundColor="{AppThemeBinding Light=#88000000, Dark=#CC000000}">
                 <Frame BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                     BorderColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                     CornerRadius="16" HasShadow="False"
                     Padding="24" WidthRequest="420"
                     HorizontalOptions="Center" VerticalOptions="Center">
                  <VerticalStackLayout Spacing="12">

                      <Label Text="{x:Static strings:AppStrings.SubjectFormat}"
                          FontSize="18"
                          FontAttributes="Bold"
                          TextColor="{AppThemeBinding Light={StaticResource OnBackgroundLight}, Dark={StaticResource OnBackgroundDark}}"
                          HorizontalOptions="Center" />

                      <Label Text="{x:Static strings:AppStrings.SubjectFormatDescription}"
                          Style="{StaticResource MutedLabel}"
                          HorizontalTextAlignment="Center"
                          LineBreakMode="WordWrap" />

                      <Label Text="{x:Static strings:AppStrings.SubjectFormatExample}"
                          Style="{StaticResource MutedLabel}"
                          HorizontalTextAlignment="Center"
                          LineBreakMode="WordWrap" />

                      <Label Text="{}&#x7B;Cliente&#x7D; | &#x7B;Progetto&#x7D; | &#x7B;Topic&#x7D;"
                          FontSize="14"
                          FontAttributes="Bold"
                          TextColor="{StaticResource Primary}"
                          HorizontalTextAlignment="Center" />

                      <!-- Lista dei template configurati -->
                      <CollectionView ItemsSource="{Binding DialogSubjectTemplates}"
                                      MaximumHeightRequest="160">
                          <CollectionView.ItemTemplate>
                              <DataTemplate x:DataType="vm:TemplateItem">
                                  <Grid ColumnDefinitions="*,Auto" Padding="4,2" ColumnSpacing="8">
                                      <Label Grid.Column="0"
                                             Text="{Binding Value}"
                                             VerticalOptions="Center"
                                             FontSize="13"
                                             TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}" />
                                      <Button Grid.Column="1"
                                              Text="✕"
                                              WidthRequest="32" HeightRequest="32"
                                              Padding="0"
                                              FontSize="12"
                                              BackgroundColor="Transparent"
                                              TextColor="{StaticResource Error}"
                                              Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveDialogTemplateCommand}"
                                              CommandParameter="{Binding .}" />
                                  </Grid>
                              </DataTemplate>
                          </CollectionView.ItemTemplate>
                      </CollectionView>

                      <!-- Aggiungi nuovo template -->
                      <Label Text="{x:Static strings:AppStrings.AddTemplateLabel}"
                          TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                          FontSize="13"
                          FontAttributes="Bold" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <Entry Grid.Column="0"
                              Text="{Binding NewDialogTemplate}"
                              TextColor="{AppThemeBinding Light={StaticResource OnSurfaceLight}, Dark={StaticResource OnSurfaceDark}}"
                              BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceVariantLight}, Dark={StaticResource SurfaceVariantDark}}"
                              PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurfaceMutedLight}, Dark={StaticResource OnSurfaceMutedDark}}"
                              Placeholder="{}&#x7B;Progetto&#x7D; - &#x7B;Topic&#x7D;"
                              Keyboard="Default"
                              FontSize="13" />
                          <Button Grid.Column="1"
                              Text="+"
                              WidthRequest="44" HeightRequest="44"
                              FontSize="20"
                              FontAttributes="Bold"
                              Style="{StaticResource SecondaryBtn}"
                              Command="{Binding AddDialogTemplateCommand}" />
                      </Grid>

                      <Button Text="{x:Static strings:AppStrings.RestoreDefault}"
                          Style="{StaticResource SecondaryBtn}"
                          HeightRequest="36"
                          FontSize="12"
                          Padding="10,0"
                          HorizontalOptions="End"
                          Command="{Binding ResetTemplateDialogCommand}" />

                      <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                       <Button Grid.Column="0"
                            Text="{x:Static strings:AppStrings.Cancel}"
                            Style="{StaticResource SecondaryBtn}"
                            HeightRequest="44"
                            Command="{Binding CancelTemplateDialogCommand}" />
                       <Button Grid.Column="1"
                            Text="{x:Static strings:AppStrings.Save}"
                            Style="{StaticResource PrimaryBtn}"
                            HeightRequest="44"
                            Command="{Binding ApplyTemplateDialogCommand}" />
                      </Grid>

                  </VerticalStackLayout>
                 </Frame>
             </Grid>

    </Grid>
</ContentPage>
