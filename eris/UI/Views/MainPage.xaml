<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eris.UI.ViewModels"
             xmlns:conv="clr-namespace:eris.UI.Converters"
             xmlns:views="clr-namespace:eris.UI.Views"
             x:Class="eris.UI.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="eris - your reports">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ToggleConfigLabel}"
                     Command="{Binding ToggleConfigCommand}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:BoolToColorConverter x:Key="AuthStatusColor"
                                   TrueColor="#16a34a"
                                   FalseColor="#64748b" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Background}">

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 1: GENERA REPORT  ═════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsGenerateTab}">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- Banner configurazione mancante -->
                <Label IsVisible="{Binding IsConfigIncomplete}"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceMuted}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,16">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Configura la sorgente per generare il report  " />
                            <Span Text="&#x2197;" FontSize="18" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <!-- Logo -->
                <Image Source="eris_logo.png"
                       HeightRequest="240"
                       HorizontalOptions="Center"
                       Margin="0,12,0,16" />

                <!-- Contenuto principale (nascosto se config incompleta) -->
                <VerticalStackLayout Spacing="0"
                                     IsVisible="{Binding IsConfigIncomplete, Converter={StaticResource InvertBool}}">

                <!-- Intestazione -->
                <Label Text="Esporta i tuoi meeting in un report"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}"
                       Margin="0,12,0,24" />

                <Label Text="Ecco il tuo report"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       IsVisible="{Binding ShowResult}"
                       Margin="0,12,0,24" />

                <!-- ── Periodo (chips) ─────────────────────────────────── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8"
                                       Margin="0,0,0,16"
                                       IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}">

                    <!-- Questa settimana -->
                    <Button Text="Questa Settimana"
                            FontSize="13" CornerRadius="20"
                            Padding="16,8" BorderWidth="1.5"
                            Command="{Binding SelectThisWeekCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsThisWeekSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsThisWeekSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                <Setter Property="BorderColor" Value="{StaticResource SurfaceVariant}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Settimana precedente -->
                    <Button Text="Settimana Precedente"
                            FontSize="13" CornerRadius="20"
                            Padding="16,8" BorderWidth="1.5"
                            Command="{Binding SelectCurrentMonthCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCurrentMonthSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCurrentMonthSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                <Setter Property="BorderColor" Value="{StaticResource SurfaceVariant}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Periodo libero -->
                    <Button Text="Periodo Libero"
                            FontSize="13" CornerRadius="20"
                            Padding="16,8" BorderWidth="1.5"
                            Command="{Binding SelectCustomPeriodCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCustomPeriodSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCustomPeriodSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                <Setter Property="BorderColor" Value="{StaticResource SurfaceVariant}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                </HorizontalStackLayout>

                <!-- Periodo selezionato -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8"
                                       Margin="0,4,0,4"
                                       IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}">
                    <Button Text="Lun – Ven"
                            FontSize="12" CornerRadius="12"
                            Padding="12,6" BorderWidth="1.5"
                            Command="{Binding ToggleWorkWeekCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsWorkWeek}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                <Setter Property="TextColor" Value="White" />
                                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsWorkWeek}" Value="False">
                                <Setter Property="BackgroundColor" Value="Transparent" />
                                <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                <Setter Property="BorderColor" Value="{StaticResource SurfaceVariant}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </HorizontalStackLayout>

                <Label Text="{Binding WeekRangeDisplay}"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}"
                       Margin="0,4,0,20" />

                <!-- ── Pulsante Genera ────────────────────────────────────── -->
                <Grid HeightRequest="52"
                      IsVisible="{Binding ShowResult, Converter={StaticResource InvertBool}}"
                      Margin="0,0,0,12">
                    <Button Style="{StaticResource PrimaryBtn}"
                            FontSize="15"
                            HeightRequest="52"
                            Command="{Binding GenerateReportCommand}"
                            HorizontalOptions="FillAndExpand">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="False">
                                <Setter Property="Text" Value="▶  Genera Report" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Text" Value="" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HeightRequest="26"
                                       WidthRequest="26" />
                </Grid>

                <!-- ── Errore ─────────────────────────────────────────────── -->
                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding HasError}"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Error}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       LineBreakMode="WordWrap"
                       Margin="0,0,0,12" />

                <!-- ── Risultato: cerchi statistiche ──────────────────────────── -->
                <HorizontalStackLayout IsVisible="{Binding ShowResult}"
                                       HorizontalOptions="Center"
                                       Spacing="20"
                                       Margin="0,0,0,8">

                    <!-- Periodo -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center"
                                         WidthRequest="150">
                        <Label Text="PERIODO"
                               FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="{StaticResource OnSurfaceMuted}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ResultPeriodStart}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center" />
                        <Label Text="–"
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceMuted}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding ResultPeriodEnd}"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <views:CircularStatView Icon="⏱"
                                            StatLabel="Ore"
                                            Value="{Binding TotalHours, StringFormat='{0:F1}h'}"
                                            Progress="{Binding HoursProgress}" />

                    <views:CircularStatView Icon="📊"
                                            StatLabel="Meeting"
                                            Value="{Binding MeetingCount, StringFormat='{0}'}"
                                            Progress="{Binding MeetingProgress}" />

                </HorizontalStackLayout>

                <!-- Bottoni post-risultato -->
                <VerticalStackLayout IsVisible="{Binding ShowResult}" Spacing="8" Margin="0,12,0,12">
                    <Button Text="Nuovo Report"
                            Style="{StaticResource SecondaryBtn}"
                            HeightRequest="52"
                            FontSize="15"
                            HorizontalOptions="FillAndExpand"
                            Command="{Binding NuovoReportCommand}" />
                    <Button Text="Apri Report"
                            Style="{StaticResource PrimaryBtn}"
                            HeightRequest="52"
                            FontSize="15"
                            HorizontalOptions="FillAndExpand"
                            Command="{Binding OpenResultCommand}" />
                </VerticalStackLayout>

                </VerticalStackLayout>
                <!-- fine: Contenuto principale -->

            </VerticalStackLayout>
        </ScrollView>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 2: CONFIGURAZIONE  ════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsConfigTab}">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- ── Sorgente Calendario ─────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12">

                        <Label Text="SORGENTE CALENDARIO"
                               Style="{StaticResource SectionTitle}" />

                        <Label Text="Sorgente dati" Style="{StaticResource MutedLabel}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="File ICS"
                                    Command="{Binding SelectSourceIcsCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Grid.Column="1"
                                    Text="Outlook Graph"
                                    Command="{Binding SelectSourceGraphCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                </VerticalStackLayout>

                <!-- ── URL ICS ─────────────────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12"
                                    IsVisible="{Binding IsIcsSource}">
                        <Label Text="FILE ICS"
                               Style="{StaticResource SectionTitle}" />
                        <Label Text="URL del file .ics" Style="{StaticResource MutedLabel}" />
                        <Entry Text="{Binding IcsUrl}"
                               TextColor="{StaticResource OnSurface}"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               PlaceholderColor="{StaticResource OnSurfaceMuted}"
                               Placeholder="https://example.com/calendar.ics"
                               Keyboard="Default"
                               FontSize="13" />
                </VerticalStackLayout>

                <!-- ── Account Microsoft ───────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12"
                                    IsVisible="{Binding IsGraphSource}">
                        <Label Text="ACCOUNT MICROSOFT"
                               Style="{StaticResource SectionTitle}" />

                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Ellipse WidthRequest="10" HeightRequest="10" VerticalOptions="Center"
                                     Fill="{Binding IsAuthenticated, Converter={StaticResource AuthStatusColor}}" />
                            <Label Text="{Binding UserDisplayName}"
                                   Style="{StaticResource SubtitleLabel}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Frame IsVisible="{Binding HasDeviceCode}"
                               BackgroundColor="#1c3448" BorderColor="#0284c7"
                               CornerRadius="8" Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Autenticazione via codice dispositivo:"
                                       Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding DeviceCodeMessage}"
                                       TextColor="{StaticResource PrimaryLight}"
                                       FontSize="12" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                            <Button Grid.Column="0"
                                    Text="Accedi con Microsoft"
                                    Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding LoginCommand}"
                                    IsVisible="{Binding IsNotAuthenticated}" />
                            <Button Grid.Column="0"
                                    Text="✓  Autenticato"
                                    Style="{StaticResource PrimaryBtn}"
                                    BackgroundColor="{StaticResource Success}"
                                    IsEnabled="False"
                                    IsVisible="{Binding IsAuthenticated}" />
                            <Button Grid.Column="1"
                                    Text="Esci"
                                    Style="{StaticResource DangerBtn}"
                                    Command="{Binding LogoutCommand}"
                                    IsVisible="{Binding IsAuthenticated}" />
                        </Grid>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="32" />
                </VerticalStackLayout>

                <!-- ── Cartella di output ──────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12">
                        <Label Text="CARTELLA DI OUTPUT"
                               Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding OutputFolder}"
                                   TextColor="{StaticResource OnSurface}"
                                   BackgroundColor="{StaticResource SurfaceVariant}"
                                   PlaceholderColor="{StaticResource OnSurfaceMuted}"
                                   Placeholder="Seleziona o digita il percorso…"
                                   FontSize="13" />
                            <Button Grid.Column="1"
                                    Text="📁"
                                    Style="{StaticResource SecondaryBtn}"
                                    WidthRequest="44"
                                    Command="{Binding SelectFolderCommand}" />
                        </Grid>
                </VerticalStackLayout>

                <!-- ── Formato esportazione ────────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12">
                        <Label Text="FORMATO ESPORTAZIONE"
                               Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="XLSX"
                                    Command="{Binding SelectFormatXlsxCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Grid.Column="1"
                                    Text="CSV"
                                    Command="{Binding SelectFormatCsvCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                </VerticalStackLayout>

                <!-- ── Ore lavorative settimanali ─────────────────────────── -->
                <VerticalStackLayout Spacing="10" Margin="0,0,0,16" Padding="0,12">
                        <Label Text="ORE LAVORATIVE SETTIMANALI"
                               Style="{StaticResource SectionTitle}" />
                        <Label Text="Monte ore di riferimento per la settimana (es. 40, 30, 36…)"
                               Style="{StaticResource MutedLabel}" />
                        <Entry Text="{Binding WeeklyWorkingHours}"
                               TextColor="{StaticResource OnSurface}"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               PlaceholderColor="{StaticResource OnSurfaceMuted}"
                               Placeholder="40"
                               Keyboard="Numeric"
                               FontSize="13" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Dialog selezione periodo ──────────────────────────────────── -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsDatePickerOpen}"
              BackgroundColor="#CC000000">
            <Frame BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource SurfaceVariant}"
                   CornerRadius="16" HasShadow="False"
                   Padding="28" WidthRequest="320"
                   HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="16">

                    <Label Text="Seleziona Periodo"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="DA" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceMuted}" />
                        <DatePicker Date="{Binding DialogStartDate}"
                                    Format="dd/MM/yyyy"
                                    TextColor="{StaticResource OnSurface}"
                                    BackgroundColor="{StaticResource SurfaceVariant}"
                                    HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="A" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceMuted}" />
                        <DatePicker Date="{Binding DialogEndDate}"
                                    Format="dd/MM/yyyy"
                                    TextColor="{StaticResource OnSurface}"
                                    BackgroundColor="{StaticResource SurfaceVariant}"
                                    HorizontalOptions="FillAndExpand" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Grid.Column="0" Text="Annulla"
                                Style="{StaticResource SecondaryBtn}"
                                HeightRequest="44"
                                Command="{Binding CancelDatePickerCommand}" />
                        <Button Grid.Column="1" Text="Conferma"
                                Style="{StaticResource PrimaryBtn}"
                                HeightRequest="44"
                                Command="{Binding ConfirmDatePickerCommand}" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
