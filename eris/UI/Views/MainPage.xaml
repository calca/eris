<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eris.UI.ViewModels"
             xmlns:conv="clr-namespace:eris.UI.Converters"
             xmlns:pages="clr-namespace:eris.UI.Views.Pages"
             xmlns:dialogs="clr-namespace:eris.UI.Views.Components.Dialogs"
             x:Class="eris.UI.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ThemeLabel}"
                     Command="{Binding ToggleThemeCommand}" />
        <ToolbarItem Text="{Binding ToggleConfigLabel}"
                     Command="{Binding ToggleConfigCommand}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:BoolToColorConverter x:Key="AuthStatusColor"
                                   TrueColor="#16a34a"
                                   FalseColor="#64748b" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 1: HOME  ═════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <pages:HomePageView Grid.Row="1"
                            IsVisible="{Binding IsGenerateTab}"
                    BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}" />

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 2: CONFIGURAZIONE  ════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
                <pages:SettingsPageView Grid.Row="1"
                                IsVisible="{Binding IsConfigTab}"
                                                                BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}" />

        <dialogs:DateRangeDialogView Grid.RowSpan="2"
                                                                         BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}"
                         IsVisible="{Binding IsDatePickerOpen}" />
        <dialogs:FiltersDialogView Grid.RowSpan="2"
                                                                     BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}"
                       IsVisible="{Binding IsFiltersDialogOpen}" />
        <dialogs:TemplateDialogView Grid.RowSpan="2"
                                                                        BindingContext="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext}"
                        IsVisible="{Binding IsTemplateDialogOpen}" />

    </Grid>
</ContentPage>
