<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:eris.UI.ViewModels"
             xmlns:conv="clr-namespace:eris.UI.Converters"
             x:Class="eris.UI.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="eris - weekly report">

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
        <conv:BoolToColorConverter x:Key="AuthStatusColor"
                                   TrueColor="#16a34a"
                                   FalseColor="#64748b" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Background}">

        <!-- ── Header Bar ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
              BackgroundColor="{StaticResource Surface}" Padding="16,10">
            <Label Text="eris"
                   FontSize="17" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}"
                   VerticalOptions="Center">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding IsConfigTab}" Value="True">
                        <Setter Property="Text" Value="⚙️  Configurazione" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding IsConfigTab}" Value="False">
                        <Setter Property="Text" Value="" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Button Grid.Column="1"
                    Command="{Binding ToggleConfigCommand}"
                    FontSize="13" FontAttributes="Bold"
                    CornerRadius="8" BorderWidth="0"
                    Padding="14,8">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsConfigTab}" Value="False">
                        <Setter Property="Text" Value="⚙️  Configurazione" />
                        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}" />
                        <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsConfigTab}" Value="True">
                        <Setter Property="Text" Value="✕  Chiudi" />
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 1: GENERA REPORT  ═════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsGenerateTab}">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- Logo -->
                <Image Source="eris_logo.png"
                       HeightRequest="240"
                       HorizontalOptions="Center"
                       Margin="0,0,0,16" />

                <!-- Intestazione -->
                <Label Text="Esporta i tuoi meeting in report settimanale"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="FillAndExpand"
                       Margin="0,12,0,24" />

                <!-- ── Periodo ───────────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,0,0,12">

                    <!-- Questa settimana -->
                    <Frame Grid.Column="0" Padding="10,10" CornerRadius="10"
                           HasShadow="False" BorderColor="Transparent"
                           BackgroundColor="{StaticResource SurfaceVariant}">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsThisWeekSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                        </Frame.Triggers>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectThisWeekCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="Questa settimana" FontAttributes="Bold" FontSize="12"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsThisWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsThisWeekSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding ThisWeekDisplay}" FontSize="11"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsThisWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsThisWeekSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Settimana scorsa -->
                    <Frame Grid.Column="1" Padding="10,10" CornerRadius="10"
                           HasShadow="False" BorderColor="Transparent"
                           BackgroundColor="{StaticResource SurfaceVariant}">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsLastWeekSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                        </Frame.Triggers>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectLastWeekCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="Settimana scorsa" FontAttributes="Bold" FontSize="12"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLastWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLastWeekSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding LastWeekDisplay}" FontSize="11"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLastWeekSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsLastWeekSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource OnSurfaceMuted}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Periodo libero -->
                    <Frame Grid.Column="2" Padding="10,10" CornerRadius="10"
                           HasShadow="False" BorderColor="Transparent"
                           BackgroundColor="{StaticResource SurfaceVariant}">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsCustomPeriodSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            </DataTrigger>
                        </Frame.Triggers>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCustomPeriodCommand}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                            <Label Text="Periodo libero" FontAttributes="Bold" FontSize="12"
                                   HorizontalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCustomPeriodSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCustomPeriodSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding CustomPeriodDisplay}" FontSize="11"
                                   HorizontalOptions="Center"
                                   IsVisible="{Binding IsCustomPeriodSelected, Converter={StaticResource InvertBool}}"
                                   TextColor="{StaticResource OnSurfaceMuted}" />
                            <VerticalStackLayout IsVisible="{Binding IsCustomPeriodSelected}"
                                                 Spacing="4" Margin="0,6,0,0">
                                <Label Text="DA" FontSize="10" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" />
                                <DatePicker Date="{Binding CustomStartDate}"
                                            Format="dd/MM/yyyy"
                                            TextColor="White"
                                            HorizontalOptions="FillAndExpand" />
                                <Label Text="A" FontSize="10" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" />
                                <DatePicker Date="{Binding CustomEndDate}"
                                            Format="dd/MM/yyyy"
                                            TextColor="White"
                                            HorizontalOptions="FillAndExpand" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- ── Pulsante Genera ────────────────────────────────────── -->
                <Button Text="▶  Genera Report"
                        Style="{StaticResource PrimaryBtn}"
                        FontSize="16"
                        HeightRequest="52"
                        Command="{Binding GenerateReportCommand}"
                        Margin="0,0,0,12" />

                <!-- ── Status bar ─────────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6"
                      Margin="0,0,0,12"
                      IsVisible="{Binding HasStatusMessage}">
                    <Label Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           TextColor="{Binding StatusColor}"
                           FontSize="13"
                           VerticalOptions="Center"
                           LineBreakMode="WordWrap" />
                    <Button Grid.Column="1"
                            Text="📋" FontSize="12"
                            WidthRequest="36" HeightRequest="36"
                            Padding="0" BackgroundColor="Transparent"
                            Command="{Binding CopyStatusCommand}"
                            VerticalOptions="Center"
                            ToolTipProperties.Text="Copia messaggio" />
                </Grid>

                <!-- ── Card: Risultato ────────────────────────────────────── -->
                <Frame Style="{StaticResource Card}"
                       IsVisible="{Binding ShowResult}">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="✅  REPORT GENERATO"
                               Style="{StaticResource SectionTitle}"
                               TextColor="{StaticResource Success}" />

                        <!-- Statistiche -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding MeetingCount}"
                                       Style="{StaticResource StatNumber}" />
                                <Label Text="Meeting"
                                       Style="{StaticResource StatCaption}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding TotalHours, StringFormat='{0:F1}h'}"
                                       Style="{StaticResource StatNumber}" />
                                <Label Text="Ore totali"
                                       Style="{StaticResource StatCaption}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label Text="{Binding WeekNumber, StringFormat='W{0}'}"
                                       Style="{StaticResource StatNumber}" />
                                <Label Text="Settimana"
                                       Style="{StaticResource StatCaption}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource SurfaceVariant}"
                                 Margin="0,4" />

                        <!-- Percorsi file -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📄" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding DetailPath}"
                                   Style="{StaticResource MutedLabel}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📊" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding SummaryPath}"
                                   Style="{StaticResource MutedLabel}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand" />
                        </HorizontalStackLayout>

                        <!-- Apri cartella -->
                        <Button Text="📂  Apri cartella"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding OpenResultFolderCommand}"
                                HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- ══  TAB 2: CONFIGURAZIONE  ════════════════════════════════════ -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsConfigTab}">
            <VerticalStackLayout Padding="20,20,20,32" Spacing="0">

                <!-- ── Card: Sorgente Calendario ─────────────────────────── -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="📡  SORGENTE CALENDARIO"
                               Style="{StaticResource SectionTitle}" />

                        <Label Text="Sorgente dati" Style="{StaticResource MutedLabel}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="File ICS"
                                    Command="{Binding SelectSourceIcsCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsIcsSource}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Grid.Column="1"
                                    Text="Outlook Graph"
                                    Command="{Binding SelectSourceGraphCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsGraphSource}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Card: URL ICS ─────────────────────────────────────── -->
                <Frame Style="{StaticResource Card}"
                       IsVisible="{Binding IsIcsSource}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🔗  FILE ICS"
                               Style="{StaticResource SectionTitle}" />
                        <Label Text="URL del file .ics" Style="{StaticResource MutedLabel}" />
                        <Entry Text="{Binding IcsUrl}"
                               TextColor="{StaticResource OnSurface}"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               PlaceholderColor="{StaticResource OnSurfaceMuted}"
                               Placeholder="https://example.com/calendar.ics"
                               Keyboard="Url"
                               FontSize="13" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Card: Account Microsoft ───────────────────────────── -->
                <Frame Style="{StaticResource Card}"
                       IsVisible="{Binding IsGraphSource}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🔐  ACCOUNT MICROSOFT"
                               Style="{StaticResource SectionTitle}" />

                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Ellipse WidthRequest="10" HeightRequest="10" VerticalOptions="Center"
                                     Fill="{Binding IsAuthenticated, Converter={StaticResource AuthStatusColor}}" />
                            <Label Text="{Binding UserDisplayName}"
                                   Style="{StaticResource SubtitleLabel}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Frame IsVisible="{Binding HasDeviceCode}"
                               BackgroundColor="#1c3448" BorderColor="#0284c7"
                               CornerRadius="8" Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Autenticazione via codice dispositivo:"
                                       Style="{StaticResource MutedLabel}" />
                                <Label Text="{Binding DeviceCodeMessage}"
                                       TextColor="{StaticResource PrimaryLight}"
                                       FontSize="12" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsBusy, Converter={StaticResource InvertBool}}">
                            <Button Grid.Column="0"
                                    Text="Accedi con Microsoft"
                                    Style="{StaticResource PrimaryBtn}"
                                    Command="{Binding LoginCommand}"
                                    IsVisible="{Binding IsNotAuthenticated}" />
                            <Button Grid.Column="0"
                                    Text="✓  Autenticato"
                                    Style="{StaticResource PrimaryBtn}"
                                    BackgroundColor="{StaticResource Success}"
                                    IsEnabled="False"
                                    IsVisible="{Binding IsAuthenticated}" />
                            <Button Grid.Column="1"
                                    Text="Esci"
                                    Style="{StaticResource DangerBtn}"
                                    Command="{Binding LogoutCommand}"
                                    IsVisible="{Binding IsAuthenticated}" />
                        </Grid>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="{StaticResource Primary}"
                                           HeightRequest="32" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Card: Cartella di output ──────────────────────────── -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📁  CARTELLA DI OUTPUT"
                               Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding OutputFolder}"
                                   TextColor="{StaticResource OnSurface}"
                                   BackgroundColor="{StaticResource SurfaceVariant}"
                                   PlaceholderColor="{StaticResource OnSurfaceMuted}"
                                   Placeholder="Seleziona o digita il percorso…"
                                   FontSize="13" />
                            <Button Grid.Column="1"
                                    Text="📁"
                                    Style="{StaticResource SecondaryBtn}"
                                    WidthRequest="44"
                                    Command="{Binding SelectFolderCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Card: Formato esportazione ────────────────────────── -->
                <Frame Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📄  FORMATO ESPORTAZIONE"
                               Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="XLSX"
                                    Command="{Binding SelectFormatXlsxCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsXlsxFormat}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            <Button Grid.Column="1"
                                    Text="CSV"
                                    Command="{Binding SelectFormatCsvCommand}">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="True">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleSelected}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsCsvFormat}" Value="False">
                                        <Setter Property="Style" Value="{StaticResource WeekToggleUnselected}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
