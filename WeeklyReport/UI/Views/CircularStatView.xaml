<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="eris.UI.Views.CircularStatView"
             x:Name="self">

    <Grid WidthRequest="150" HeightRequest="150">

        <GraphicsView x:Name="RingView"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill" />

        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="2">
            <Label Text="{Binding Source={x:Reference self}, Path=Icon}"
                   FontSize="18"
                   HorizontalOptions="Center"
                   TextColor="#64748b" />
            <Label Text="{Binding Source={x:Reference self}, Path=StatLabel}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="#94a3b8" />
            <Label Text="{Binding Source={x:Reference self}, Path=Value}"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#f1f5f9" />
        </VerticalStackLayout>

    </Grid>
</ContentView>
